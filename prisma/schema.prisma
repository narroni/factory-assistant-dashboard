generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  WORKER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MaterialStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  PROTOTYPE
}

enum OrderStatus {
  PENDING
  IN_PRODUCTION
  COMPLETED
  DELAYED
  CANCELLED
}

enum SupplierStatus {
  ACTIVE
  WARNING
  INACTIVE
}

enum MovementType {
  RECEIPT
  CONSUMPTION
  ADJUSTMENT
  RETURN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// ── User ──────────────────────────────────────────────────────────────────────

model User {
  id                  String     @id @default(cuid())
  name                String
  email               String     @unique
  passwordHash        String?
  role                UserRole   @default(VIEWER)
  status              UserStatus @default(ACTIVE)
  lastLoginAt         DateTime?
  forcePasswordChange Boolean    @default(false)

  auditLogs           AuditLog[]
  aiActionRequests    AIActionRequest[]  @relation("AIActionCreator")
  aiActionApprovals   AIActionRequest[]  @relation("AIActionApprover")
  executedActions     ExecutedAction[]
  aiInteractionLogs   AIInteractionLog[]
  assistantChats      AssistantChat[]
  factoryKnowledge    FactoryKnowledge[]
  aiRules             AIRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Supplier ──────────────────────────────────────────────────────────────────

model Supplier {
  id           String         @id @default(cuid())
  code         String         @unique
  name         String
  contact      String
  email        String         @unique
  phone        String?
  country      String
  leadTimeDays Int
  onTimeRate   Float
  status       SupplierStatus @default(ACTIVE)

  materials SupplierMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("suppliers")
}

// ── SupplierMaterial (join table) ─────────────────────────────────────────────

model SupplierMaterial {
  id         String @id @default(cuid())
  supplierId String
  materialId String

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([supplierId, materialId])
  @@map("supplier_materials")
}

// ── Material ──────────────────────────────────────────────────────────────────

model Material {
  id       String         @id @default(cuid())
  code     String         @unique
  name     String
  category String
  quantity Float
  unit     String
  status   MaterialStatus @default(IN_STOCK)

  suppliers           SupplierMaterial[]
  productRequirements ProductMaterialRequirement[]
  stockMovements      StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@map("materials")
}

// ── Product ───────────────────────────────────────────────────────────────────

model Product {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  primaryMaterial String
  notes           String?

  lengthMm    Float
  widthMm     Float
  thicknessMm Float
  weightKg    Float
  volumeM3    Float

  status ProductStatus @default(ACTIVE)

  materialRequirements ProductMaterialRequirement[]
  orders               Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("products")
}

// ── ProductMaterialRequirement ────────────────────────────────────────────────

model ProductMaterialRequirement {
  id         String   @id @default(cuid())
  productId  String
  materialId String?

  name     String
  qtyValue Float
  qtyUnit  String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([materialId])
  @@map("product_material_requirements")
}

// ── Order ─────────────────────────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customer    String
  customerId  String?
  productId   String?
  productName String
  productCode String
  qty         Int
  status      OrderStatus @default(PENDING)
  dueDate     DateTime
  valueEur    Float

  product     Product?  @relation(fields: [productId],  references: [id], onDelete: SetNull)
  customerRel Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines       OrderLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customer])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("orders")
}

// ── StockMovement ─────────────────────────────────────────────────────────────

model StockMovement {
  id         String       @id @default(cuid())
  materialId String
  type       MovementType
  qtyDelta   Float
  unit       String
  note       String?

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([materialId])
  @@index([type])
  @@map("stock_movements")
}

// ── DatabaseBackup ────────────────────────────────────────────────────────────

model DatabaseBackup {
  id          String   @id @default(cuid())
  filename    String
  sizeBytes   Int
  createdBy   String
  note        String?

  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("database_backups")
}

// ── Assistant Chat ────────────────────────────────────────────────────────────

model AssistantChat {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Chat")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AssistantMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([updatedAt])
  @@map("assistant_chats")
}

enum AssistantMessageStatus {
  PENDING
  COMPLETED
  FAILED
}

model AssistantMessage {
  id              String @id @default(cuid())
  chatId          String
  role            String  // "user" | "assistant"
  content         String
  ollamaUsed      Boolean @default(false)
  proposals       Json?
  savedRequestIds Json?   // array of AIActionRequest IDs
  status          AssistantMessageStatus @default(COMPLETED)

  chat       AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chatId])
  @@index([status])
  @@map("assistant_messages")
}

// ── AI Action Request ─────────────────────────────────────────────────────────

enum AIActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

model AIActionRequest {
  id              String         @id @default(cuid())
  createdByUserId String
  actionType      String
  payload         Json
  reasoning       String
  status          AIActionStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?

  createdByUser User  @relation("AIActionCreator",  fields: [createdByUserId], references: [id])
  approver      User? @relation("AIActionApprover", fields: [approvedBy],      references: [id])
  executedAction ExecutedAction?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdByUserId])
  @@map("ai_action_requests")
}

// ── Executed Action ───────────────────────────────────────────────────────────

model ExecutedAction {
  id              String   @id @default(cuid())
  requestId       String   @unique
  actionType      String
  outputType      String   // "xlsx" | "pdf" | "text" | "json"
  outputFile      String?  // file path or URL
  outputContent   String?  // for text-based outputs
  executedBy      String
  metadata        Json?    // action-specific metadata

  request         AIActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  executor        User            @relation(fields: [executedBy], references: [id])

  createdAt       DateTime @default(now())

  @@index([requestId])
  @@index([actionType])
  @@index([createdAt])
  @@map("executed_actions")
}

// ── AI Interaction Log ────────────────────────────────────────────────────────

model AIInteractionLog {
  id              String   @id @default(cuid())
  userId          String
  prompt          String
  intent          String?
  response        String
  ollamaUsed      Boolean  @default(false)
  actionsProposed Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_interaction_logs")
}

// ── AI Configuration ──────────────────────────────────────────────────────────

model AIConfig {
  id                String  @id @default("singleton")
  assistantName     String  @default("Factory Copilot")
  systemPrompt      String  @default("")
  responseStyle     String  @default("concise") // "concise" | "detailed"
  defaultLanguage   String  @default("en")
  allowedActions    Json    @default("[]") // array of action types

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_config")
}

model FactoryKnowledge {
  id          String   @id @default(cuid())
  filename    String
  fileType    String   // "txt" | "csv" | "xlsx" | "pdf"
  fileSize    Int
  content     String   @db.Text // extracted text or summary
  metadata    Json?    // file-specific metadata
  enabled     Boolean  @default(true)
  uploadedBy  String

  user        User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  chunks      KnowledgeChunk[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([uploadedBy])
  @@index([createdAt])
  @@map("factory_knowledge")
}

// ── AuditLog ──────────────────────────────────────────────────────────────────

model AuditLog {
  id       String      @id @default(cuid())
  entity   String
  entityId String
  action   AuditAction
  userId   String?

  before Json?
  after  Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Packaging / Container Calculation ─────────────────────────────────────────

model CrateType {
  id              String  @id @default(cuid())
  code            String  @unique
  emptyWeightKg   Float
  xMeters         Float
  yMeters         Float
  zMeters         Float
  hasLegs         Boolean @default(false)
  legsDescription String?

  bladeProducts   BladeProductSpec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("crate_types")
}

model ContainerType {
  id            String @id @default(cuid())
  name          String @unique
  lengthMeters  Float
  widthMeters   Float
  maxVolumeM3   Float
  maxPayloadKg  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("container_types")
}

model BladeProductSpec {
  id                     String  @id @default(cuid())
  articleCode            String  @unique
  productName            String
  lengthMm               Float
  widthMm                Float
  thicknessMm            Float
  tpi                    Int
  punchedOn              String
  holeDistance           String?
  holeSize               String?
  color                  String
  weightBeforePunchingKg Float
  weightAfterPunchingKg  Float
  pcsPerCrate            Int
  crateTypeId            String
  maxCratesPerTower      Int

  crateType   CrateType   @relation(fields: [crateTypeId], references: [id])
  orderLines  OrderLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([crateTypeId])
  @@map("blade_product_specs")
}

model PackagingCalculation {
  id               String  @id @default(cuid())
  articleCode      String
  productName      String
  qty              Int
  containerName    String
  requiredCrates   Float
  fullCrates       Int
  towers           Int
  netWeightKg      Float
  crateWeightKg    Float
  totalWeightKg    Float
  footprintM2      Float
  volumeM3         Float
  weightFits       Boolean
  areaFits         Boolean
  volumeFits       Boolean
  overallFits      Boolean
  limitingFactors  String?
  maxPiecesFit     Int

  createdAt DateTime @default(now())

  @@index([articleCode])
  @@index([createdAt])
  @@map("packaging_calculations")
}

// ── Customer ──────────────────────────────────────────────────────────────────

model Customer {
  id          String  @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  notes       String?

  orders      Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("customers")
}

// ── OrderLine ─────────────────────────────────────────────────────────────────

model OrderLine {
  id             String @id @default(cuid())
  orderId        String
  bladeProductId String
  articleCode    String
  productName    String
  qty            Int

  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bladeProduct BladeProductSpec @relation(fields: [bladeProductId], references: [id])

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([bladeProductId])
  @@map("order_lines")
}

// ── AI Rules ──────────────────────────────────────────────────────────────────

model AIRule {
  id        String  @id @default(cuid())
  text      String  @db.Text
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  createdBy String

  user User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@index([createdBy])
  @@map("ai_rules")
}

// ── Knowledge Chunks (RAG foundation) ─────────────────────────────────────────

model KnowledgeChunk {
  id          String @id @default(cuid())
  knowledgeId String
  chunkIndex  Int
  content     String @db.Text
  tokenCount  Int?

  knowledge  FactoryKnowledge    @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  embedding  KnowledgeEmbedding?

  createdAt DateTime @default(now())

  @@index([knowledgeId])
  @@map("knowledge_chunks")
}

// ── Knowledge Embeddings placeholder (future vector search) ───────────────────

model KnowledgeEmbedding {
  id      String @id @default(cuid())
  chunkId String @unique
  model   String @default("none")
  vector  Json   @default("[]")

  chunk KnowledgeChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("knowledge_embeddings")
}
