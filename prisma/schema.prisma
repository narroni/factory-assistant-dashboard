generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  WORKER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum MaterialStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  PROTOTYPE
}

enum OrderStatus {
  PENDING
  IN_PRODUCTION
  COMPLETED
  DELAYED
  CANCELLED
}

enum SupplierStatus {
  ACTIVE
  WARNING
  INACTIVE
}

enum MovementType {
  RECEIPT
  CONSUMPTION
  ADJUSTMENT
  RETURN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// ── User ──────────────────────────────────────────────────────────────────────

model User {
  id                  String     @id @default(cuid())
  name                String
  email               String     @unique
  passwordHash        String?
  role                UserRole   @default(VIEWER)
  status              UserStatus @default(ACTIVE)
  lastLoginAt         DateTime?
  forcePasswordChange Boolean    @default(false)

  auditLogs           AuditLog[]
  aiActionRequests    AIActionRequest[]  @relation("AIActionCreator")
  aiActionApprovals   AIActionRequest[]  @relation("AIActionApprover")
  aiInteractionLogs   AIInteractionLog[]
  assistantChats      AssistantChat[]
  factoryKnowledge    FactoryKnowledge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ── Supplier ──────────────────────────────────────────────────────────────────

model Supplier {
  id           String         @id @default(cuid())
  code         String         @unique
  name         String
  contact      String
  email        String         @unique
  phone        String?
  country      String
  leadTimeDays Int
  onTimeRate   Float
  status       SupplierStatus @default(ACTIVE)

  materials SupplierMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("suppliers")
}

// ── SupplierMaterial (join table) ─────────────────────────────────────────────

model SupplierMaterial {
  id         String @id @default(cuid())
  supplierId String
  materialId String

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([supplierId, materialId])
  @@map("supplier_materials")
}

// ── Material ──────────────────────────────────────────────────────────────────

model Material {
  id       String         @id @default(cuid())
  code     String         @unique
  name     String
  category String
  quantity Float
  unit     String
  status   MaterialStatus @default(IN_STOCK)

  suppliers           SupplierMaterial[]
  productRequirements ProductMaterialRequirement[]
  stockMovements      StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@map("materials")
}

// ── Product ───────────────────────────────────────────────────────────────────

model Product {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  primaryMaterial String
  notes           String?

  lengthMm    Float
  widthMm     Float
  thicknessMm Float
  weightKg    Float
  volumeM3    Float

  status ProductStatus @default(ACTIVE)

  materialRequirements ProductMaterialRequirement[]
  orders               Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("products")
}

// ── ProductMaterialRequirement ────────────────────────────────────────────────

model ProductMaterialRequirement {
  id         String   @id @default(cuid())
  productId  String
  materialId String?

  name     String
  qtyValue Float
  qtyUnit  String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([materialId])
  @@map("product_material_requirements")
}

// ── Order ─────────────────────────────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customer    String
  productId   String?
  productName String
  productCode String
  qty         Int
  status      OrderStatus @default(PENDING)
  dueDate     DateTime
  valueEur    Float

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customer])
  @@index([status])
  @@index([dueDate])
  @@map("orders")
}

// ── StockMovement ─────────────────────────────────────────────────────────────

model StockMovement {
  id         String       @id @default(cuid())
  materialId String
  type       MovementType
  qtyDelta   Float
  unit       String
  note       String?

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([materialId])
  @@index([type])
  @@map("stock_movements")
}

// ── DatabaseBackup ────────────────────────────────────────────────────────────

model DatabaseBackup {
  id          String   @id @default(cuid())
  filename    String
  sizeBytes   Int
  createdBy   String
  note        String?

  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("database_backups")
}

// ── Assistant Chat ────────────────────────────────────────────────────────────

model AssistantChat {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Chat")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AssistantMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([updatedAt])
  @@map("assistant_chats")
}

model AssistantMessage {
  id         String @id @default(cuid())
  chatId     String
  role       String  // "user" | "assistant"
  content    String
  ollamaUsed Boolean @default(false)
  proposals  Json?

  chat       AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([chatId])
  @@map("assistant_messages")
}

// ── AI Action Request ─────────────────────────────────────────────────────────

enum AIActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

model AIActionRequest {
  id              String         @id @default(cuid())
  createdByUserId String
  actionType      String
  payload         Json
  reasoning       String
  status          AIActionStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?

  createdByUser User  @relation("AIActionCreator",  fields: [createdByUserId], references: [id])
  approver      User? @relation("AIActionApprover", fields: [approvedBy],      references: [id])

  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdByUserId])
  @@map("ai_action_requests")
}

// ── AI Interaction Log ────────────────────────────────────────────────────────

model AIInteractionLog {
  id              String   @id @default(cuid())
  userId          String
  prompt          String
  intent          String?
  response        String
  ollamaUsed      Boolean  @default(false)
  actionsProposed Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_interaction_logs")
}

// ── AI Configuration ──────────────────────────────────────────────────────────

model AIConfig {
  id                String  @id @default("singleton")
  assistantName     String  @default("Factory Copilot")
  systemPrompt      String  @default("")
  responseStyle     String  @default("concise") // "concise" | "detailed"
  defaultLanguage   String  @default("en")
  allowedActions    Json    @default("[]") // array of action types

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_config")
}

model FactoryKnowledge {
  id          String   @id @default(cuid())
  filename    String
  fileType    String   // "txt" | "csv" | "xlsx" | "pdf"
  fileSize    Int
  content     String   @db.Text // extracted text or summary
  metadata    Json?    // file-specific metadata
  enabled     Boolean  @default(true)
  uploadedBy  String

  user        User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([uploadedBy])
  @@index([createdAt])
  @@map("factory_knowledge")
}

// ── AuditLog ──────────────────────────────────────────────────────────────────

model AuditLog {
  id       String      @id @default(cuid())
  entity   String
  entityId String
  action   AuditAction
  userId   String?

  before Json?
  after  Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
